venv/
__pycache__/
*.pyc
.DS_Store

# Cache (embeddings, chunks, brand profile)
cache/

# Output files (regenerated on each run)
output/

# Per-site audit snapshots — never commit client/prospect data to a public repo
runs/

# Local-only: per-prospect site configs that shouldn't live in a public repo.
# Keep generic templates in examples/sites/ but actual prospect configs go in .local/.
.local/
examples/sites/*.yaml
!examples/sites/example.yaml

# Environment
.env

# Local archive (old client runs quarantined out of source)
.archive/

# GitHub Pages staging dir (built fresh by scripts/build_pages_index.py during CI)
public/

# Per-run artifacts uploaded by GitHub Actions matrix jobs
artifacts/

# Local claude-flow session state
.claude-flow/
